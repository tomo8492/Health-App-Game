<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- MARK: - アプリ基本情報 -->
	<key>CFBundleDisplayName</key>
	<string>VITA CITY</string>
	<key>CFBundleIdentifier</key>
	<string>com.vitacity.app</string>
	<key>CFBundleName</key>
	<string>VitaCity</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>ja</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<!-- MARK: - 対応デバイス・向き（iPhone 縦向き固定: CLAUDE.md）-->
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer><!-- iPhone のみ -->
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- MARK: - HealthKit 使用説明（必須: App Store 審査要件）-->
	<!--
	  Apple 審査では「具体的に何のデータを」「何の目的で」使うかを明確にすることが
	  推奨されている。拒否されやすい表現（"better experience", "improve the app"）は避け、
	  機能と直結した説明にする。
	-->
	<key>NSHealthShareUsageDescription</key>
	<string>街の発展に使う健康ポイント（CP）を自動計算するため、歩数・消費カロリー・ワークアウト・睡眠時間を読み取ります。すべてのデータは iPhone 内にのみ保存され、外部サーバーには送信されません。</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>VITA CITY は HealthKit への書き込みを行いません。この項目は iOS の要件により記載されています。</string>

	<!-- MARK: - モーション&フィットネス（iOS のペドメータ API を補助的に使用する場合）-->
	<key>NSMotionUsageDescription</key>
	<string>歩数カウントを補助的に取得し、街のキャラクターの動きに反映するために使用します。データはデバイス内にのみ保存されます。</string>

	<!-- MARK: - ユーザー通知（日次リマインダー・ストリーク警告）-->
	<key>NSUserNotificationUsageDescription</key>
	<string>日次の記録リマインダーや連続記録達成の通知をお届けするために使用します。設定からいつでも無効化できます。</string>

	<!-- MARK: - バックグラウンドモード（歩数の HKObserverQuery: CLAUDE.md Key Rule 7）-->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>

	<!-- MARK: - App Transport Security -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<!-- MARK: - Scene Configuration（SwiftUI @main App ライフサイクル: SceneDelegate 不要）-->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>

	<!-- MARK: - その他 -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDefault</string>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
